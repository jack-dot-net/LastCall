# Port the server listens on. Render injects this automatically.
PORT=3001

# Node environment ("development" or "production")
NODE_ENV=development

# Comma-separated list of origins allowed by CORS / Socket.IO in dev.
# Leave empty in production — server defaults to same-origin.
CORS_ORIGINS=http://localhost:5173

# Directory where JSON persistence files are written.
# Defaults to ./data relative to the project root.
DATA_DIR=./data
